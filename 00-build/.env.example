# Copy to .env and fill in. .env is gitignored, never commit your key.

# Your model provider key (Anthropic / Claude).
ANTHROPIC_API_KEY=sk-ant-...

# Model + bounds. These ARE your M5 deliverable, tune and justify them.
CORTEX_MODEL=claude-haiku-4-5-20251001   # cheap, fast Claude model; a full run is ~cents
CORTEX_MAX_ITERATIONS=8       # loop cap: stop + escalate instead of spinning
CORTEX_MAX_REVISIONS=2        # critic<->drafter cap: stop the bounce-forever bomb
CORTEX_COST_CAP_USD=0.50      # hard spend cap per run, enforced outside the model
CORTEX_MAX_QUEUE_ITEMS=10     # commitment cap: max backlog stories queued per run

# Rough $ per 1M tokens for your chosen model (for the in-code cost estimate).
# Defaults below match Claude Haiku 4.5 ($1 in / $5 out per 1M tokens).
CORTEX_PRICE_IN_PER_M=1.0
CORTEX_PRICE_OUT_PER_M=5.0
